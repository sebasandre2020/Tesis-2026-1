               <div class=\"bg-red-600 px-3 py-1.5 text-[9px] mono font-bold text-white shadow-xs\" data-kid=\"188\">\n                                PEAK DETECTED\n                            </div>\n                            <div class=\"w-px h-8 bg-red-600 mx-auto\" data-kid=\"189\"></div>\n                        </div>\n\n                        \n                        <div class=\"absolute -bottom-8 w-full flex justify-between text-[9px] mono text-gray-400\" data-kid=\"190\">\n                            <span data-kid=\"191\">14:00</span>\n                            <span data-kid=\"192\">18:00</span>\n                            <span data-kid=\"193\">22:00</span>\n                            <span data-kid=\"194\">02:00</span>\n                            <span data-kid=\"195\">06:00</span>\n                            <span data-kid=\"196\">10:00</span>\n                            <span data-kid=\"197\">14:00</span>\n                        </div>\n                    </div>\n                </div>\n            </section>\n\n            \n            <section class=\"grid grid-cols-1 md:grid-cols-3 gap-10 pb-12\" data-kid=\"198\">\n                \n                \n                <div class=\"stats-col\" data-kid=\"199\">\n                    <h4 class=\"text-[10px] font-extrabold text-gray-400 mb-6 flex items-center gap-2 uppercase tracking-[0.1em]\" data-kid=\"200\">\n                        <i class=\"ti ti-chart-bar text-gray-400\" data-kid=\"201\"></i> Estadísticas Generales\n                    </h4>\n                    <div class=\"space-y-3.5 border-t border-[var(--border-hairline)] pt-6\" data-kid=\"202\">\n                        <div class=\"flex justify-between items-center border-b border-gray-100 pb-2.5\" data-kid=\"203\">\n                            <span class=\"text-[10px] font-bold text-gray-500 uppercase tracking-wide\" data-kid=\"204\">Promedio Diario</span>\n                            <span class=\"mono text-sm font-bold text-gray-800\" data-kid=\"205\">984 <span class=\"text-[9px] text-gray-400 font-normal\" data-kid=\"206\">PPM</span></span>\n                        </div>\n                        <div class=\"flex justify-between items-center border-b border-gray-100 pb-2.5\" data-kid=\"207\">\n                            <span class=\"text-[10px] font-bold text-gray-500 uppercase tracking-wide\" data-kid=\"208\">Pico Máximo</span>\n                            <span class=\"mono text-sm font-bold text-red-500\" data-kid=\"209\">1240 <span class=\"text-[9px] text-gray-400 font-normal\" data-kid=\"210\">PPM</span></span>\n                        </div>\n                        <div class=\"flex justify-between items-center border-b border-gray-100 pb-2.5\" data-kid=\"211\">\n                            <span class=\"text-[10px] font-bold text-gray-500 uppercase tracking-wide\" data-kid=\"212\">Eficiencia HVAC</span>\n                            <span class=\"mono text-sm font-bold text-gray-800\" data-kid=\"213\">92.4 <span class=\"text-[9px] text-gray-400 font-normal\" data-kid=\"214\">%</span></span>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"history-col\" data-kid=\"215\">\n                    <h4 class=\"text-[10px] font-extrabold text-gray-400 mb-6 flex items-center gap-2 uppercase tracking-[0.1em]\" data-kid=\"216\">\n                        <i class=\"ti ti-history text-gray-400\" data-kid=\"217\"></i> Historial de Eventos\n                    </h4>\n                    <div class=\"max-h-[280px] overflow-y-auto dense-scroll mono text-[9px] border-t border-[var(--border-hairline)] pt-4 space-y-1 pr-2\" data-kid=\"218\">\n                        <div class=\"flex items-start gap-3 p-2 bg-gray-50 border-l border-gray-300\" data-kid=\"219\">\n                            <span class=\"text-gray-400 shrink-0\" data-kid=\"220\">14:02:11</span>\n                            <span class=\"uppercase font-bold text-gray-400 shrink-0\" data-kid=\"221\">[INFO]</span>\n                            <span class=\"text-gray-600 leading-tight\" data-kid=\"222\">Sincronización Nodo 1 exitosa.</span>\n                        </div>\n                        <div class=\"flex items-start gap-3 p-2 bg-white\" data-kid=\"223\">\n                            <span class=\"text-gray-400 shrink-0\" data-kid=\"224\">13:58:22</span>\n                            <span class=\"uppercase font-bold text-gray-400 shrink-0\" data-kid=\"225\">[INFO]</span>\n                            <span class=\"text-gray-600 leading-tight\" data-kid=\"226\">Calibración automática iniciada.</span>\n                        </div>\n                        <div class=\"flex items-start gap-3 p-2 bg-amber-50 border-l border-amber-200\" data-kid=\"227\">\n                            <span class=\"text-gray-400 shrink-0\" data-kid=\"228\">13:45:00</span>\n                            <span class=\"uppercase font-bold text-amber-600 shrink-0\" data-kid=\"229\">[WARN]</span>\n                            <span class=\"text-amber-800 leading-tight\" data-kid=\"230\">Variación térmica > 2°C detectada.</span>\n                        </div>\n                        <div class=\"flex items-start gap-3 p-2 bg-white\" data-kid=\"231\">\n                            <span class=\"text-gray-400 shrink-0\" data-kid=\"232\">13:30:15</span>\n                            <span class=\"uppercase font-bold text-gray-400 shrink-0\" data-kid=\"233\">[SYS]</span>\n                            <span class=\"text-gray-600 leading-tight\" data-kid=\"234\">Actualización firmware: SNSR-042.</span>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"alerts-col\" data-kid=\"235\">\n                    <h4 class=\"text-[10px] font-extrabold text-gray-400 mb-6 flex items-center gap-2 uppercase tracking-[0.1em]\" data-kid=\"236\">\n                        <i class=\"ti ti-alert-triangle text-red-500\" data-kid=\"237\"></i> Alertas Activas\n                    </h4>\n                    <div class=\"space-y-3 border-t border-[var(--border-hairline)] pt-6\" data-kid=\"238\">\n                        <div class=\"p-4 bg-white border border-[var(--border-hairline)] border-l-2 border-l-red-500 relative flex justify-between items-center group cursor-pointer hover:bg-red-50 transition-colors\" data-kid=\"239\">\n                            <div data-kid=\"240\">\n                                <div class=\"flex items-center gap-2 mb-1\" data-kid=\"241\">\n                                    <span class=\"text-[9px] font-bold text-red-600 uppercase tracking-widest\" data-kid=\"242\">[ URGENTE ]</span>\n                                    <span class=\"text-[9px] mono text-gray-400\" data-kid=\"243\">13:45</span>\n                                </div>\n                                <p class=\"text-[11px] font-extrabold text-gray-800 uppercase leading-tight\" data-kid=\"244\">Umbral Crítico CO₂</p>\n                                <p class=\"text-[10px] text-gray-500 mono mt-0.5\" data-kid=\"245\">LOBBY_NORTH_02 > 1500ppm</p>\n                            </div>\n                            <i class=\"ti ti-chevron-right text-gray-300 group-hover:text-red-500 transition-colors\" data-kid=\"246\"></i>\n                        </div>\n                        <div class=\"p-4 bg-white border border-[var(--border-hairline)] border-l-2 border-l-amber-500 relative flex justify-between items-center group cursor-pointer hover:bg-amber-50 transition-colors\" data-kid=\"247\">\n                            <div data-kid=\"248\">\n                                <div class=\"flex items-center gap-2 mb-1\" data-kid=\"249\">\n                                    <span class=\"text-[9px] font-bold text-amber-600 uppercase tracking-widest\" data-kid=\"250\">[ AVISO ]</span>\n                                    <span class=\"text-[9px] mono text-gray-400\" data-kid=\"251\">12:30</span>\n                                </div>\n                                <p class=\"text-[11px] font-extrabold text-gray-800 uppercase leading-tight\" data-kid=\"252\">Batería Baja</p>\n                                <p class=\"text-[10px] text-gray-500 mono mt-0.5\" data-kid=\"253\">SNSR-012 (Biblioteca)</p>\n                            </div>\n                            <i class=\"ti ti-chevron-right text-gray-300 group-hover:text-amber-500 transition-colors\" data-kid=\"254\"></i>\n                        </div>\n                    </div>\n                </div>\n            </section>\n        </div>\n    </main>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"255\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"256\"></script>\n<script data-kid=\"257\">\n    gsap.registerPlugin(ScrollTrigger);\n\n    window.addEventListener('DOMContentLoaded', () => {\n        // Entrance animations\n        gsap.from(\".sensor-card\", {\n            y: 20,\n            autoAlpha: 0,\n            duration: 0.6,\n            stagger: 0.1,\n            ease: \"power2.out\"\n        });\n\n        gsap.from(\".filter-card\", {\n            x: 20,\n            autoAlpha: 0,\n            duration: 0.6,\n            delay: 0.3,\n            ease: \"power2.out\"\n        });\n\n        // Numerical counters\n        document.querySelectorAll('.counter-value').forEach(counter => {\n            const target = parseInt(counter.getAttribute('data-target'));\n            const state = { value: 0 };\n            gsap.to(state, {\n                value: target,\n                duration: 1.5,\n                ease: \"power3.out\",\n                onUpdate: () => {\n                    counter.textContent = Math.round(state.value);\n                }\n            });\n        });\n\n        // Path drawing for the main chart\n        const mainPath = document.querySelector('#main-path');\n        if (mainPath) {\n            const length = mainPath.getTotalLength();\n            gsap.set(mainPath, { strokeDasharray: length, strokeDashoffset: length });\n            gsap.to(mainPath, { \n                strokeDashoffset: 0, \n                duration: 2, \n                ease: \"expo.out\",\n                scrollTrigger: {\n                    trigger: \".main-chart-container\",\n                    start: \"top 80%\"\n                }\n            });\n        }\n\n        // Sparklines animation\n        document.querySelectorAll('.sparkline-path').forEach(spark => {\n            const length = spark.getTotalLength();\n            gsap.set(spark, { strokeDasharray: length, strokeDashoffset: length });\n            gsap.to(spark, { \n                strokeDashoffset: 0, \n                duration: 1.2, \n                ease: \"power2.out\", \n                delay: 0.8 \n            });\n        });\n\n        // Bottom panels reveal\n        gsap.from(\".stats-col, .history-col, .alerts-col\", {\n            y: 15,\n            autoAlpha: 0,\n            duration: 0.6,\n            stagger: 0.1,\n            scrollTrigger: {\n                trigger: \".stats-col\",\n                start: \"top 95%\"\n            }\n        });\n    });\n</script>",
