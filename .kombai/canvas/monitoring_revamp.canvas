kid=\"236\">\n                    <div class=\"flex gap-1.5\" data-kid=\"237\">\n                        <div class=\"w-2.5 h-2.5 rounded-full bg-[#ff5f56]\" data-kid=\"238\"></div>\n                        <div class=\"w-2.5 h-2.5 rounded-full bg-[#ffbd2e]\" data-kid=\"239\"></div>\n                        <div class=\"w-2.5 h-2.5 rounded-full bg-[#27c93f]\" data-kid=\"240\"></div>\n                    </div>\n                    <span class=\"text-[9px] text-white/30 uppercase tracking-widest\" data-kid=\"241\">utec@telemetry_server: ~ / monitor_stream</span>\n                </div>\n                <div id=\"terminal-stream\" class=\"p-6 h-[250px] overflow-y-auto text-[12px] text-[var(--accent-cyan)] scroll-smooth\" data-kid=\"242\">\n                    <div class=\"space-y-1 pb-10\" data-kid=\"243\">\n                        <p class=\"text-white/40 font-mono\" data-kid=\"244\">[14:44:01] utec_mon --start-stream --verbose</p>\n                        <p class=\"text-white/40 font-mono\" data-kid=\"245\">[14:44:01] Establishing node handshake...</p>\n                        <p class=\"text-white font-mono\" data-kid=\"246\">[14:44:02] Connected to 42 sensors in 4 zones.</p>\n                        <p class=\"font-mono text-[var(--accent-cyan)]\" data-kid=\"247\">[14:44:03] NODE_01 DATA RECEIVED: {CO2: 742, TMP: 23.4, HUM: 68%}</p>\n                        <p class=\"font-mono text-[var(--accent-cyan)]\" data-kid=\"248\">[14:44:04] NODE_03 DATA RECEIVED: {CO2: 969, TMP: 22.4, HUM: 71%}</p>\n                        <p class=\"font-mono text-red-500 font-bold\" data-kid=\"249\">[14:44:05] ALERT: NODE_02 CO2 THRESHOLD EXCEEDED (1284 > 1000)</p>\n                        <p class=\"font-mono text-white/40\" data-kid=\"250\">[14:44:05] Automatic purge sequence initiated in Zone_Auditorium...</p>\n                        <p class=\"font-mono text-[var(--accent-cyan)]\" data-kid=\"251\">[14:44:06] NODE_04 DATA RECEIVED: {CO2: 1042, TMP: 24.8, HUM: 65%}</p>\n                        <p class=\"font-mono text-[var(--accent-cyan)]\" data-kid=\"252\">[14:44:07] NODE_01 DATA RECEIVED: {CO2: 741, TMP: 23.4, HUM: 68%}</p>\n                        <p class=\"font-mono text-[var(--accent-cyan)]\" data-kid=\"253\">[14:44:08] NODE_03 DATA RECEIVED: {CO2: 968, TMP: 22.4, HUM: 71%}</p>\n                        <div class=\"flex items-center\" data-kid=\"254\">\n                            <span class=\"text-white mr-2\" data-kid=\"255\">utec@control-center:~$</span>\n                            <span class=\"cursor-blink\" data-kid=\"256\"></span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n    </main>\n\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"257\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"258\"></script>\n    <script type=\"module\" data-kid=\"259\">\n    import Lenis from \"https://esm.sh/lenis@1\"\n    import { animate, scroll } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n    gsap.registerPlugin(ScrollTrigger);\n\n    const lenis = new Lenis({\n        lerp: 0.1,\n        smoothWheel: true\n    });\n\n    lenis.on('scroll', ScrollTrigger.update);\n    gsap.ticker.add((time) => {\n        lenis.raf(time * 1000);\n    });\n    gsap.ticker.lagSmoothing(0);\n\n    scroll((p, info) => {\n        if (info.y.velocity > 0 && info.y.current > 100) {\n            animate(\"#main-header\", { y: \"-100%\" }, { duration: 0.3, ease: \"easeOut\" });\n        } else if (info.y.velocity < 0) {\n            animate(\"#main-header\", { y: \"0%\" }, { duration: 0.3, ease: \"easeOut\" });\n        }\n    });\n\n    // Enhanced HUD Entrance\n    gsap.set(\".telemetry-card\", { clipPath: \"polygon(0 0, 0 0, 0 100%, 0 100%)\", opacity: 0 });\n    gsap.to(\".telemetry-card\", {\n        clipPath: \"polygon(0 0, 100% 0, 100% 100%, 0 100%)\",\n        opacity: 1,\n        duration: 1.5,\n        stagger: 0.2,\n        ease: \"expo.out\",\n        scrollTrigger: {\n            trigger: \".widget-canvas\",\n            start: \"top 95%\",\n        }\n    });\n\n    scroll(\n        animate(\"#blueprint-map\", { scale: [0.8, 1], opacity: [0.3, 1] }),\n        {\n            target: document.querySelector(\".blueprint-canvas\"),\n            offset: [\"start end\", \"center center\"]\n        }\n    );\n\n    const terminal = document.getElementById('terminal-stream');\n    const terminalContent = terminal.querySelector('.space-y-1');\n    const lines = [\n        '[14:44:09] NODE_02 STATUS UPDATE: VENTILATION FANS @ 100%',\n        '[14:44:10] NODE_01 DATA RECEIVED: {CO2: 740, TMP: 23.3}',\n        '[14:44:11] HEARTBEAT_PULSE: ALL NODES SYNCHRONIZED',\n        '[14:44:12] NODE_04 DATA RECEIVED: {CO2: 1038, TMP: 24.7}'\n    ];\n    \n    let lineIndex = 0;\n    setInterval(() => {\n        if (lineIndex < lines.length) {\n            const p = document.createElement('p');\n            p.className = 'font-mono text-[var(--accent-cyan)]';\n            p.textContent = lines[lineIndex];\n            terminalContent.insertBefore(p, terminalContent.lastElementChild);\n            \n            gsap.from(p, { opacity: 0, x: -10, duration: 0.5 });\n            terminal.scrollTo({\n                top: terminal.scrollHeight,\n                behavior: 'smooth'\n            });\n            lineIndex++;\n        }\n    }, 4000);\n</script>\n",
