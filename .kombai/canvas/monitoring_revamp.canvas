      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Fira+Sans:wght@400;500;700&family=Fira+Code&display=swap');\n    \n    :root {\n        --bg-ink: #010B13;\n        --text-platinum: #F2F3F4;\n        --accent-cyan: #00A4E4;\n        --glass-highlight: rgba(255, 255, 255, 0.05);\n    }\n\n    .font-space { font-family: 'Space Grotesk', sans-serif; }\n    .font-fira { font-family: 'Fira Sans', sans-serif; }\n    .font-mono { font-family: 'Fira Code', monospace; }\n\n    /* HUD Frame Utility */\n    .hud-frame {\n        position: relative;\n        background: rgba(0, 164, 228, 0.02);\n        clip-path: polygon(\n            0% 12px, 12px 0%, \n            calc(100% - 12px) 0%, 100% 12px, \n            100% calc(100% - 12px), calc(100% - 12px) 100%, \n            12px 100%, 0% calc(100% - 12px)\n        );\n        border: 1px solid rgba(242, 243, 244, 0.08);\n    }\n\n    .hud-frame::before {\n        content: '';\n        position: absolute;\n        top: 0; left: 0; right: 0; bottom: 0;\n        pointer-events: none;\n        border: 1px solid rgba(0, 164, 228, 0.15);\n        clip-path: polygon(\n            0% 12px, 12px 0%, \n            calc(100% - 12px) 0%, 100% 12px, \n            100% calc(100% - 12px), calc(100% - 12px) 100%, \n            12px 100%, 0% calc(100% - 12px)\n        );\n    }\n\n    .hud-frame-glow::after {\n        content: '';\n        position: absolute;\n        top: 0; left: 50%;\n        transform: translateX(-50%);\n        width: 30%;\n        height: 1px;\n        background: var(--accent-cyan);\n        box-shadow: 0 0 12px var(--accent-cyan);\n    }\n\n    .neon-inset-alarm {\n        border: 1px solid #ef4444;\n        box-shadow: 0 0 20px rgba(239, 68, 68, 0.3), inset 0 0 30px rgba(239, 68, 68, 0.08);\n        background: rgba(239, 68, 68, 0.03);\n    }\n\n    /* Glassmorphism */\n    .glass-header {\n        backdrop-filter: blur(12px);\n        background: rgba(1, 11, 19, 0.85);\n        border-bottom: 1px solid rgba(242, 243, 244, 0.1);\n    }\n\n    .glass-header::after {\n        content: '';\n        position: absolute;\n        bottom: 0; left: 0;\n        width: 100%; height: 1px;\n        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);\n    }\n\n    /* Blueprint Layout */\n    .blueprint-canvas {\n        background-color: #010B13;\n        background-image: \n            linear-gradient(rgba(0, 164, 228, 0.03) 1px, transparent 1px),\n            linear-gradient(90deg, rgba(0, 164, 228, 0.03) 1px, transparent 1px);\n        background-size: 30px 30px;\n        border: 1px solid rgba(0, 164, 228, 0.1);\n        overflow: hidden;\n    }\n\n    /* Animations */\n    .hud-reveal {\n        clip-path: polygon(0 0, 0 0, 0 100%, 0% 100%);\n    }\n\n    @keyframes pulse-dot {\n        0% { transform: scale(0.8); opacity: 0.8; }\n        50% { transform: scale(1.2); opacity: 1; }\n        100% { transform: scale(0.8); opacity: 0.8; }\n    }\n    .animate-dot {\n        animation: pulse-dot 2s infinite ease-in-out;\n    }\n\n    .cursor-blink {\n        display: inline-block;\n        width: 8px;\n        height: 18px;\n        background-color: var(--accent-cyan);\n        animation: blink 1s step-end infinite;\n    }\n    @keyframes blink {\n        50% { opacity: 0; }\n    }\n\n    .delta-pill-up {\n        background: rgba(239, 68, 68, 0.1);\n        color: #ef4444;\n        border: 1px solid rgba(239, 68, 68, 0.2);\n    }\n    .delta-pill-down {\n        background: rgba(34, 197, 94, 0.1);\n        color: #22c55e;\n        border: 1px solid rgba(34, 197, 94, 0.2);\n    }\n\n    /* Prevent text selection in dashboard */\n    .dashboard-container {\n        user-select: none;\n        background-color: var(--bg-ink);\n        color: var(--text-platinum);\n    }\n</style>\n\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"1\">\n<link href=\"https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css\" rel=\"stylesheet\" data-kid=\"2\">\n\n<div class=\"dashboard-container font-fira min-h-screen overflow-x-clip\" data-kid=\"3\">\n    \n    <header id=\"main-header\" class=\"fixed top-0 left-0 right-0 z-50 glass-header px-6 py-4 flex items-center justify-between\" data-kid=\"4\">\n        <div class=\"flex items-center gap-4\" data-kid=\"5\">\n            <div class=\"w-10 h-10 bg-[var(--accent-cyan)] rounded flex items-center justify-center text-black font-bold text-xl\" data-kid=\"6\">\n                U\n            </div>\n            <div data-kid=\"7\">\n                <h1 class=\"text-sm font-bold tracking-widest uppercase font-space\" data-kid=\"8\">UTEC AIR MONITOR</h1>\n                <p class=\"text-[10px] text-white/40 tracking-[0.2em]\" data-kid=\"9\">CONTROL CENTER V2.4 // LIVE DATA</p>\n            </div>\n        </div>\n\n        \n        <div class=\"hidden md:flex items-center gap-6 flex-1 max-w-2xl px-12\" style=\"mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);\" data-kid=\"10\">\n            <span class=\"text-[10px] text-white/40 font-mono\" data-kid=\"11\">00:00</span>\n            <div class=\"relative flex-1 h-px bg-white/10\" data-kid=\"12\">\n                <div class=\"absolute top-1/2 left-[65%] -translate-y-1/2 w-3 h-3 bg-[var(--accent-cyan)] rounded-full shadow-[0_0_10px_var(--accent-cyan)] cursor-pointer\" data-kid=\"13\"></div>\n                <div class=\"absolute top-[-4px] left-0 w-full flex justify-between px-1\" data-kid=\"14\">\n                    <div class=\"h-2 w-px bg-white/20\" data-kid=\"15\"></div>\n                    <div class=\"h-2 w-px bg-white/20\" data-kid=\"16\"></div>\n                    <div class=\"h-2 w-px bg-white/20\" data-kid=\"17\"></div>\n                    <div class=\"h-2 w-px bg-white/20\" data-kid=\"18\"></div>\n                    <div class=\"h-2 w-px bg-white/20\" data-kid=\