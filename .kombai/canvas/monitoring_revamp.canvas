      "html": "<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=IBM+Plex+Mono:wght@400;500;600&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    :root {\n        --utec-cyan: #00A4E4;\n        --bg-primary: #FFFFFF;\n        --text-primary: #1A1A1A;\n        --border-hairline: #E5E7EB;\n        --surface-muted: #F9FAFB;\n    }\n\n    .dashboard-root {\n        font-family: 'Manrope', sans-serif;\n        color: var(--text-primary);\n        background-color: var(--bg-primary);\n        display: flex;\n        min-height: 100vh;\n        overflow-x: clip;\n    }\n\n    .mono {\n        font-family: 'IBM Plex Mono', monospace;\n    }\n\n    .hairline-border {\n        border: 1px solid var(--border-hairline);\n    }\n\n    .sidebar-item-active::before {\n        content: '';\n        position: absolute;\n        left: 0;\n        top: 25%;\n        height: 50%;\n        width: 2px;\n        background-color: var(--utec-cyan);\n    }\n\n    .dense-scroll::-webkit-scrollbar {\n        width: 4px;\n    }\n    .dense-scroll::-webkit-scrollbar-track {\n        background: transparent;\n    }\n    .dense-scroll::-webkit-scrollbar-thumb {\n        background: #D1D5DB;\n        border-radius: 10px;\n    }\n</style>\n\n<div class=\"dashboard-root\" data-kid=\"1\">\n    \n    <aside class=\"w-14 border-r border-[var(--border-hairline)] flex flex-col items-center py-5 gap-6 bg-white fixed h-full z-20\" data-kid=\"2\">\n        <div class=\"mb-2\" data-kid=\"3\">\n            <div class=\"w-7 h-7 bg-[var(--utec-cyan)] flex items-center justify-center text-white font-bold text-[10px]\" data-kid=\"4\">U</div>\n        </div>\n        \n        <nav class=\"flex flex-col gap-4\" data-kid=\"5\">\n            <a href=\"#\" class=\"relative p-2.5 text-[var(--utec-cyan)] sidebar-item-active\" data-kid=\"6\">\n                <i class=\"ti ti-layout-dashboard text-lg\" data-kid=\"7\"></i>\n            </a>\n            <a href=\"#\" class=\"p-2.5 text-gray-300 hover:text-[var(--text-primary)] transition-colors\" data-kid=\"8\">\n                <i class=\"ti ti-activity text-lg\" data-kid=\"9\"></i>\n            </a>\n            <a href=\"#\" class=\"p-2.5 text-gray-300 hover:text-[var(--text-primary)] transition-colors\" data-kid=\"10\">\n                <i class=\"ti ti-history text-lg\" data-kid=\"11\"></i>\n            </a>\n            <a href=\"#\" class=\"p-2.5 text-gray-300 hover:text-[var(--text-primary)] transition-colors\" data-kid=\"12\">\n                <i class=\"ti ti-settings text-lg\" data-kid=\"13\"></i>\n            </a>\n        </nav>\n\n        <div class=\"mt-auto flex flex-col gap-3\" data-kid=\"14\">\n            <button class=\"p-2.5 text-gray-300 hover:text-red-500 transition-colors\" data-kid=\"15\">\n                <i class=\"ti ti-bell-filled text-lg\" data-kid=\"16\"></i>\n            </button>\n            <div class=\"w-7 h-7 rounded-full bg-gray-100 flex items-center justify-center text-[9px] mono font-bold border border-gray-200\" data-kid=\"17\">\n                JD\n            </div>\n        </div>\n    </aside>\n\n    \n    <main class=\"flex-1 ml-14 bg-[var(--surface-muted)] min-h-screen\" data-kid=\"18\">\n        \n        \n        <header class=\"h-14 bg-white border-b border-[var(--border-hairline)] flex items-center justify-between px-6 sticky top-0 z-10\" data-kid=\"19\">\n            <div class=\"flex items-center gap-4\" data-kid=\"20\">\n                <h1 class=\"text-xs font-extrabold uppercase tracking-widest text-[var(--text-primary)]\" data-kid=\"21\">\n                    Control Center <span class=\"text-gray-300 font-normal mx-2\" data-kid=\"22\">/</span> <span class=\"text-[var(--utec-cyan)]\" data-kid=\"23\">UTEC Campus</span>\n                </h1>\n                <div class=\"flex items-center gap-1.5 px-2 py-0.5 bg-cyan-50 border border-cyan-100 rounded-sm\" data-kid=\"24\">\n                    <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--utec-cyan)] animate-pulse\" data-kid=\"25\"></span>\n                    <span class=\"text-[9px] font-bold text-[var(--utec-cyan)] mono uppercase\" data-kid=\"26\">Live</span>\n                </div>\n            </div>\n            \n            <div class=\"flex items-center gap-6\" data-kid=\"27\">\n                <div class=\"text-right\" data-kid=\"28\">\n                    <p class=\"text-[9px] font-bold text-gray-400 uppercase leading-none mb-1\" data-kid=\"29\">Last Update</p>\n                    <p class=\"text-xs mono font-medium\" data-kid=\"30\">12 Oct 2023 • 14:02:11</p>\n                </div>\n                <div class=\"h-8 w-px bg-[var(--border-hairline)]\" data-kid=\"31\"></div>\n                <div class=\"flex gap-2 text-xs mono\" data-kid=\"32\">\n                    <span class=\"text-gray-400\" data-kid=\"33\">STATUS:</span>\n                    <span class=\"text-green-600 font-bold uppercase\" data-kid=\"34\">Optimal</span>\n                </div>\n            </div>\n        </header>\n\n        <div class=\"p-6 space-y-6 max-w-[1400px] mx-auto\" data-kid=\"35\">\n            \n            \n            <section class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4\" data-kid=\"36\">\n                \n                \n                <div class=\"bg-white border border-[var(--border-hairline)] p-5 relative overflow-hidden group sensor-card\" data-kid=\"37\">\n                    <div class=\"absolute top-0 left-0 w-full h-[2px] bg-[var(--utec-cyan)]\" data-kid=\"38\"></div>\n                    <div class=\"flex justify-between items-start mb-3\" data-kid=\"39\">\n                        <div data-kid=\"40\">\n                            <h3 class=\"font-bold text-sm tracking-tight text-gray-800\" data-kid=\"41\">Aula 101</h3>\n                            <p class=\"text-[10px] text-gray-400 mono\" data-kid=\"42\">PISO 1 • SNSR-042</p>\n                        </div>\n                        <div class=\"flex items-center gap-1.5\" data-kid=\"43\">\n                            <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--utec-cyan)]\" data-kid=\"44\"></span>\n                            <span class=\"text-[9px] font-bold text-[var(--utec-cyan)] mono\" data-kid=\"45\">LIVE</span>\n                        </div>\n                    </div>\n                    \n                    <div class=\"mb-3\" data-kid=\"46\">\n                        <span class=\"text-[10px] font-medium text-gray-400 block mb-0.5 uppercase tracking-wide\" data-kid=\"47\">CO₂ Concentración</span>\n                        <div class=\"flex items-baseline gap-1.5\" data-kid=\"48\">\n                            <span class=\"text-4xl font-extrabold mono tracking-tighter counter-value\" data-target=\"1022\" data-kid=\"49\">0</span>\n                            <span class=\"text-[10px] font-semibold text-gray-400 mono uppercase\" data-kid=\"50\">ppm</span>\n                        </div>\n                    </div>\n\n                    <div class=\"space-y-2 mb-4 border-t border-[var(--border-hairline)] pt-3\" data-kid=\"51\">\n                        <div class=\"flex justify-between items-center text-[11px]\" data-kid=\"52\">\n                            <span class=\"text-gray-500 flex items-center gap-1.5\" data-kid=\"53\"><i class=\"ti ti-grain text-gray-400\" data-kid=\"54\"></i> Polvo</span>\n                            <span class=\"mono font-semibold\" data-kid=\"55\">62 <span class=\"text-gray-400 font-normal\" data-kid=\"56\">µg/m³</span></span>\n                        </div>\n                        <div class=\"flex justify-between items-center text-[11px]\" data-kid=\"57\">\n                            <span class=\"text-gray-500 flex items-center gap-1.5\" data-kid=\"58\"><i class=\"ti ti-thermometer text-gray-400\" data-kid=\"59\"></i> Temp</span>\n                            <span class=\"mono font-semibold\" data-kid=\"60\">23.1 <span class=\"text-gray-400 font-normal\" data-kid=\"61\">°C</span></span>\n                        </div>\n                        <div class=\"flex justify-between items-center text-[11px]\" data-kid=\"62\">\n                            <span class=\"text-gray-500 flex items-center gap-1.5\" data-kid=\"63\"><i class=\"ti ti-droplet text-gray-400\" data-kid=\"64\"></i> Humedad</span>\n                            <span class=\"mono font-semibold\" data-kid=\"65\">77.9 <span class=\"text-gray-400 font-normal\" data-kid=\"66\">%</span></span>\n                        </div>\n                    </div>\n\n                    <div class=\"h-6 w-full\" data-kid=\"67\">\n                        <svg class=\"w-full h-full overflow-visible\" viewBox=\"0 0 100 30\" preserveAspectRatio=\"none\" data-kid=\"68\">\n                            <path class=\"sparkline-path\" d=\"M0 25 Q 10 28, 20 15 T 40 20 T 60 10 T 80 15 T 100 5\" fill=\"none\" stroke=\"var(--utec-cyan)\" stroke-width=\"1.5\" data-kid=\"69\"></path>\n                        </svg>\n                    </div>\n                </div>\n\n                \n                <div class=\"bg-white border border-[var(--border-hairline)] p-5 relative overflow-hidden group sensor-card\" data-kid=\"70\">\n                    <div class=\"absolute top-0 left-0 w-full h-[2px] bg-[var(--utec-cyan)] opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"71\"></div>\n                    <div class=\"flex justify-between items-start mb-3\" data-kid=\"72\">\n                        <div data-kid=\"73\">\n                            <h3 class=\"font-bold text-sm tracking-tight text-gray-800\" data-kid=\"74\">Laboratorio</h3>\n                            <p class=\"text-[10px] text-gray-400 mono\" data-kid=\"75\">PISO 2 • SNSR-089</p>\n                        </div>\n                        <i class=\"ti ti-flask text-gray-400\" data-kid=\"76\"></i>\n                    </div>\n                    \n                    <div class=\"mb-3\" data-kid=\"77\">\n                        <span class=\"text-[10px] font-medium text-gray-400 block mb-0.5 uppercase tracking-wide\" data-kid=\"78\">CO₂ Concentración</span>\n                        <div class=\"flex items-baseline gap-1.5\" data-kid=\"79\">\n                            <span class=\"text-4xl font-extrabold mono tracking-tighter counter-value\" data-target=\"1099\" data-kid=\"80\">0</span>\n                            <span class=\"text-[10px] font-semibold text-gray-400 mono uppercase\" data-kid=\"81\">ppm</span>\n                        </div>\n                    </div>\n\n                    <div class=\"space-y-2 mb-4 border-t border-[var(--border-hairline)] pt-3\" data-kid=\"82\">\n                        <div class=\"flex justify-between items-center text-[11px]\" data-kid=\"83\">\n                            <span class=\"text-gray-500 flex items-center gap-1.5\" data-kid=\"84\"><i class=\"ti ti-grain text-gray-400\" data-kid=\"85\"></i> Polvo</span>\n                            <span class=\"mono font-semibold\" data-kid=\"86\">72 <span class=\"text-gray-400 font-normal\" data-kid=\"87\">µg/m³</span></span>\n                        </div>\n                        <div class=\"flex justify-between items-center text-[11px]\" data-kid=\"88\">\n                            <span class=\"text-gray-500 flex items-center gap-1.5\" data-kid=\"89\"><i class=\"ti ti-thermometer text-gray-400\" data-kid=\"90\"></i> Temp</span>\n                            <span class=\"mono font-semibold\" data-kid=\"91\">23.8 <span class=\"text-gray-400 font-normal\" data-kid=\"92\">°C</span></span>\n                        </div>\n                        <div class=\"flex justify-between items-center text-[11px]\" data-kid=\"93\">\n                            <span class=\"text-gray-500 flex items-center gap-1.5\" data-kid=\"94\"><i class=\"ti ti-droplet text-gray-400\" data-kid=\"95\"></i> Humedad</span>\n                            <span class=\"mono font-semibold\" data-kid=\"96\">79.4 <span class=\"text-gray-400 font-normal\" data-kid=\"97\">%</span></span>\n                        </div>\n                    </div>\n\n                    <div class=\"h-6 w-full\" data-kid=\"98\">\n                        <svg class=\"w-full h-full overflow-visible\" viewBox=\"0 0 100 30\" preserveAspectRatio=\"none\" data-kid=\"99\">\n                            <path class=\"sparkline-path\" d=\"M0 15 Q 15 10, 30 25 T 50 15 T 70 20 T 100 10\" fill=\"none\" stroke=\"var(--utec-cyan)\" stroke-width=\"1.5\" data-kid=\"100\"></path>\n                        </svg>\n                    </div>\n                </div>\n\n                \n                <div class=\"bg-white border border-[var(--border-hairline)] p-5 relative overflow-hidden group sensor-card\" data-kid=\"101\">\n                    <div class=\"absolute top-0 left-0 w-full h-[2px] bg-[var(--utec-cyan)] opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"102\"></div>\n                    <div class=\"flex justify-between items-start mb-3\" data-kid=\"103\">\n                        <div data-kid=\"104\">\n                            <h3 class=\"font-bold text-sm tracking-tight text-gray-800\" data-kid=\"105\">Biblioteca</h3>\n                            <p class=\"text-[10px] text-gray-400 mono\" data-kid=\"106\">PISO 1 • SNSR-012</p>\n                        </div>\n                        <i class=\"ti ti-books text-gray-400\" data-kid=\"107\"></i>\n                    </div>\n                    \n                    <div class=\"mb-3\" data-kid=\"108\">\n                        <span class=\"text-[10px] font-medium text-gray-400 block mb-0.5 uppercase tracking-wide\" data-kid=\"109\">CO₂ Concentración</span>\n                        <div class=\"flex items-baseline gap-1.5\" data-kid=\"110\">\n                            <span class=\"text-4xl font-extrabold mono tracking-tighter counter-value\" data-target=\