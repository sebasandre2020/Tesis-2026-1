      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap');\n\n    :root {\n        --color-bg: #FFFFFF;\n        --color-text: #0B0E14;\n        --color-accent: #00A4E4;\n        --color-border: #0B0E14;\n    }\n\n    body {\n        margin: 0;\n        padding: 0;\n        background-color: var(--color-bg);\n        color: var(--color-text);\n        font-family: 'IBM Plex Sans', sans-serif;\n        overflow-x: clip;\n    }\n\n    .font-mono {\n        font-family: 'IBM Plex Mono', monospace;\n    }\n\n    .hairline {\n        border: 1px solid var(--color-border);\n    }\n\n    .hairline-b {\n        border-bottom: 1px solid var(--color-border);\n    }\n\n    .hairline-r {\n        border-right: 1px solid var(--color-border);\n    }\n\n    .nav-item {\n        position: relative;\n    }\n\n    .nav-item .hover-bar {\n        position: absolute;\n        left: 0;\n        top: 0;\n        bottom: 0;\n        width: 3px;\n        transform: scaleY(0);\n        transform-origin: center;\n    }\n\n    .nav-item:hover .hover-bar, .nav-item.active .hover-bar {\n        transform: scaleY(1);\n    }\n\n    ::-webkit-scrollbar {\n        width: 4px;\n        height: 4px;\n    }\n    ::-webkit-scrollbar-track {\n        background: transparent;\n    }\n    ::-webkit-scrollbar-thumb {\n        background: var(--color-border);\n    }\n\n    .reveal-card {\n        opacity: 0;\n        transform: translateY(16px);\n    }\n</style>\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"1\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"2\">\n\n<div class=\"flex min-h-screen\" data-kid=\"3\">\n    \n    <aside class=\"w-16 flex flex-col items-center hairline-r py-6 gap-8 shrink-0 sticky top-0 h-screen bg-white z-50\" data-kid=\"4\">\n       