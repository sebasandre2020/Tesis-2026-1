ust</button>\n                    </div>\n                </div>\n\n                <div class=\"relative h-[400px] w-full mt-4 pl-12 pb-14\" data-kid=\"153\">\n                    \n                    <div class=\"absolute left-0 top-0 h-[400px] flex flex-col justify-between text-[10px] font-mono opacity-40 pr-4 border-r border-[#0B0E14]/10 pointer-events-none\" data-kid=\"154\">\n                        <span data-kid=\"155\">1400</span>\n                        <span data-kid=\"156\">1050</span>\n                        <span data-kid=\"157\">700</span>\n                        <span data-kid=\"158\">350</span>\n                        <span data-kid=\"159\">0</span>\n                    </div>\n\n                    <div class=\"h-full relative border-b border-[#0B0E14]/20\" data-kid=\"160\">\n                         \n                        <div class=\"absolute inset-0 flex flex-col justify-between pointer-events-none\" data-kid=\"161\">\n                            <div class=\"h-px w-full bg-[#0B0E14]/5\" data-kid=\"162\"></div>\n                            <div class=\"h-px w-full bg-[#0B0E14]/5\" data-kid=\"163\"></div>\n                            <div class=\"h-px w-full bg-[#0B0E14]/5\" data-kid=\"164\"></div>\n                            <div class=\"h-px w-full bg-[#0B0E14]/5\" data-kid=\"165\"></div>\n                        </div>\n\n                        <svg id=\"trend-svg\" viewBox=\"0 0 800 400\" class=\"w-full h-full overflow-visible\" preserveAspectRatio=\"none\" data-kid=\"166\">\n                            <path id=\"trend-path\" d=\"M0 350 L100 320 L200 340 L300 220 L400 150 L500 280 L600 140 L700 110 L800 100\" fill=\"none\" stroke=\"#00A4E4\" stroke-width=\"3\" vector-effect=\"non-scaling-stroke\" data-kid=\"167\"></path>\n                            \n                            \n                            <g transform=\"translate(300, 220)\" data-kid=\"168\">\n                                <circle r=\"4\" fill=\"#00A4E4\" data-kid=\"169\"></circle>\n                                <line y1=\"0\" y2=\"-60\" stroke=\"#0B0E14\" stroke-width=\"0.5\" stroke-dasharray=\"2,2\" data-kid=\"170\"></line>\n                                <rect x=\"-50\" y=\"-85\" width=\"100\" height=\"25\" fill=\"white\" stroke=\"#0B0E14\" stroke-width=\"0.5\" data-kid=\"171\"></rect>\n                                <text x=\"0\" y=\"-68\" font-size=\"9\" text-anchor=\"middle\" font-family=\"IBM Plex Mono\" font-weight=\"bold\" data-kid=\"172\">HVAC ACTIVE</text>\n                            </g>\n\n                            <g transform=\"translate(600, 140)\" data-kid=\"173\">\n                                <circle r=\"4\" fill=\"#00A4E4\" data-kid=\"174\"></circle>\n                                <line y1=\"0\" y2=\"-60\" stroke=\"#0B0E14\" stroke-width=\"0.5\" stroke-dasharray=\"2,2\" data-kid=\"175\"></line>\n                                <rect x=\"-60\" y=\"-85\" width=\"120\" height=\"25\" fill=\"white\" stroke=\"#0B0E14\" stroke-width=\"0.5\" data-kid=\"176\"></rect>\n                                <text x=\"0\" y=\"-68\" font-size=\"9\" text-anchor=\"middle\" font-family=\"IBM Plex Mono\" font-weight=\"bold\" data-kid=\"177\">PEAK OCCUPANCY</text>\n                            </g>\n                        </svg>\n\n                        \n                        <div class=\"absolute -bottom-12 left-0 w-full flex justify-between text-[10px] font-mono opacity-50 px-2 pt-2 border-t border-[#0B0E14]/5\" data-kid=\"178\">\n                            <span data-kid=\"179\">00:00</span>\n                            <span data-kid=\"180\">06:00</span>\n                            <span data-kid=\"181\">12:00</span>\n                            <span data-kid=\"182\">18:00</span>\n                            <span data-kid=\"183\">23:59</span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"col-span-12 lg:col-span-4 hairline flex flex-col reveal-card h-[524px]\" data-kid=\"184\">\n                <div class=\"p-4 hairline-b bg-[#0B0E14]/2 flex justify-between items-center\" data-kid=\"185\">\n                    <h3 class=\"font-bold uppercase text-[10px] tracking-widest\" data-kid=\"186\">System Audit Log</h3>\n                    <div class=\"flex items-center gap-1.5\" data-kid=\"187\">\n                        <span class=\"w-1.5 h-1.5 rounded-full bg-[#00A4E4] animate-pulse\" data-kid=\"188\"></span>\n                        <span class=\"text-[9px] font-mono font-bold uppercase\" data-kid=\"189\">Streaming</span>\n                    </div>\n                </div>\n                <div class=\"grow overflow-y-auto p-4 font-mono text-[10px] uppercase leading-tight space-y-0.5\" id=\"audit-log\" data-kid=\"190\">\n                    <div class=\"flex items-start gap-3 py-1 border-b border-[#0B0E14]/5\" data-kid=\"191\">\n                        <span class=\"opacity-40 shrink-0\" data-kid=\"192\">14:02:11</span>\n                        <span class=\"bg-[#00A4E4] text-white px-1 shrink-0 font-bold\" data-kid=\"193\">[ OK ]</span>\n                        <span class=\"opacity-50 shrink-0\" data-kid=\"194\">NODO_042</span>\n                        <span class=\"font-medium\" data-kid=\"195\">Self-diagnostic check passed.</span>\n                    </div>\n                    <div class=\"flex items-start gap-3 py-1 border-b border-[#0B0E14]/10 bg-[#0B0E14] text-white\" data-kid=\"196\">\n                        <span class=\"opacity-60 shrink-0 px-2\" data-kid=\"197\">14:01:04</span>\n                        <span class=\"bg-white text-[#0B0E14] px-1 shrink-0 font-bold\" data-kid=\"198\">[ CRIT ]</span>\n                        <span class=\"opacity-60 shrink-0\" data-kid=\"199\">NODO_088</span>\n                        <span class=\"font-bold pr-2\" data-kid=\"200\">CO2 EXCEEDED: 1099 PPM</span>\n                    </div>\n                     <div class=\"flex items-start gap-3 py-1 border-b border-[#0B0E14]/5\" data-kid=\"201\">\n                        <span class=\"opacity-40 shrink-0\" data-kid=\"202\">13:58:29</span>\n                        <span class=\"bg-[#0B0E14] text-white px-1 shrink-0 font-bold\" data-kid=\"203\">[ INFO ]</span>\n                        <span class=\"opacity-50 shrink-0\" data-kid=\"204\">SYSTEM</span>\n                        <span class=\"font-medium\" data-kid=\"205\">Ventilation relays switched to AUTO.</span>\n                    </div>\n                     <div class=\"flex items-start gap-3 py-1 border-b border-[#0B0E14]/5\" data-kid=\"206\">\n                        <span class=\"opacity-40 shrink-0\" data-kid=\"207\">13:55:00</span>\n                        <span class=\"bg-[#00A4E4] text-white px-1 shrink-0 font-bold\" data-kid=\"208\">[ OK ]</span>\n                        <span class=\"opacity-50 shrink-0\" data-kid=\"209\">NODO_015</span>\n                        <span class=\"font-medium\" data-kid=\"210\">Data sync successful.</span>\n                    </div>\n                </div>\n                <div class=\"p-3 hairline-t text-[8px] font-mono opacity-40 uppercase tracking-widest text-center\" data-kid=\"211\">\n                    End of buffer. Page 1/142\n                </div>\n            </div>\n\n            \n            <div class=\"col-span-12 grid grid-cols-1 md:grid-cols-4 gap-4 reveal-card\" data-kid=\"212\">\n                 <div class=\"hairline p-6 flex flex-col justify-between\" data-kid=\"213\">\n                    <span class=\"text-[9px] uppercase font-mono opacity-50\" data-kid=\"214\">Avg CO2</span>\n                    <div class=\"flex items-baseline gap-2\" data-kid=\"215\">\n                        <span class=\"text-2xl font-bold font-mono\" data-kid=\"216\">1022.4</span>\n                        <span class=\"text-[9px] font-mono opacity-60\" data-kid=\"217\">PPM</span>\n                    </div>\n                    <div class=\"w-full bg-[#0B0E14]/5 h-1 mt-2\" data-kid=\"218\">\n                        <div class=\"bg-[#00A4E4] h-full\" style=\"width: 72%\" data-kid=\"219\"></div>\n                    </div>\n                 </div>\n                 <div class=\"hairline p-6 flex flex-col justify-between bg-[#0B0E14]/2\" data-kid=\"220\">\n                    <span class=\"text-[9px] uppercase font-mono opacity-50\" data-kid=\"221\">Energy Utilization</span>\n                    <div class=\"flex items-baseline gap-2\" data-kid=\"222\">\n                        <span class=\"text-2xl font-bold font-mono\" data-kid=\"223\">88.2</span>\n                        <span class=\"text-[9px] font-mono opacity-60\" data-kid=\"224\">KW/H</span>\n                    </div>\n                    <div class=\"w-full bg-[#0B0E14]/5 h-1 mt-2\" data-kid=\"225\">\n                        <div class=\"bg-[#0B0E14] h-full\" style=\"width: 45%\" data-kid=\"226\"></div>\n                    </div>\n                 </div>\n                 <div class=\"hairline p-6 flex flex-col justify-between\" data-kid=\"227\">\n                    <span class=\"text-[9px] uppercase font-mono opacity-50\" data-kid=\"228\">System Uptime</span>\n                    <div class=\"flex items-baseline gap-2\" data-kid=\"229\">\n                        <span class=\"text-2xl font-bold font-mono\" data-kid=\"230\">99.98</span>\n                        <span class=\"text-[9px] font-mono opacity-60\" data-kid=\"231\">%</span>\n                    </div>\n                    <div class=\"w-full bg-[#0B0E14]/5 h-1 mt-2\" data-kid=\"232\">\n                        <div class=\"bg-[#00A4E4] h-full\" style=\"width: 99.98%\" data-kid=\"233\"></div>\n                    </div>\n                 </div>\n                 <div class=\"hairline p-6 flex flex-col justify-between\" data-kid=\"234\">\n                    <span class=\"text-[9px] uppercase font-mono opacity-50\" data-kid=\"235\">Storage Capacity</span>\n                    <div class=\"flex items-baseline gap-2\" data-kid=\"236\">\n                        <span class=\"text-2xl font-bold font-mono\" data-kid=\"237\">1.2</span>\n                        <span class=\"text-[9px] font-mono opacity-60\" data-kid=\"238\">TB</span>\n                    </div>\n                    <div class=\"w-full bg-[#0B0E14]/5 h-1 mt-2\" data-kid=\"239\">\n                        <div class=\"bg-[#0B0E14] h-full\" style=\"width: 12%\" data-kid=\"240\"></div>\n                    </div>\n                 </div>\n            </div>\n        </div>\n    </main>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"241\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"242\"></script>\n<script type=\"module\" data-kid=\"243\">\n  import Lenis from \"https://esm.sh/lenis@1\"\n  import { animate as animeAnimate } from 'https://esm.sh/animejs@4';\n\n  const lenis = new Lenis()\n  function raf(time) {\n    lenis.raf(time)\n    requestAnimationFrame(raf)\n  }\n  requestAnimationFrame(raf)\n\n  gsap.registerPlugin(ScrollTrigger);\n  \n  ScrollTrigger.batch(\".reveal-card\", {\n    start: \"top 95%\",\n    onEnter: (elements) => {\n      gsap.to(elements, {\n        opacity: 1,\n        y: 0,\n        duration: 0.8,\n        stagger: 0.1,\n        ease: \"power2.out\"\n      });\n    }\n  });\n\n  const animateCounter = (id, target) => {\n    const obj = { val: 0 };\n    gsap.to(obj, {\n      val: target,\n      duration: 2.5,\n      ease: \"power4.out\",\n      onUpdate: () => {\n        const el = document.getElementById(id);\n        if (el) el.textContent = Math.round(obj.val);\n      }\n    });\n  };\n\n  animateCounter(\"co2-aula-101\", 1022);\n  animateCounter(\"co2-lab\", 1099);\n  animateCounter(\"co2-biblio\", 969);\n\n  // Smooth appearance for annotations\n  gsap.from(\"#trend-svg g\", {\n    opacity: 0,\n    y: 10,\n    duration: 1,\n    stagger: 0.3,\n    delay: 2,\n    ease: \"power2.out\"\n  });\n\n  const trendPath = document.querySelector(\"#trend-path\");\n  if (trendPath) {\n      const length = trendPath.getTotalLength();\n      gsap.set(trendPath, { strokeDasharray: length, strokeDashoffset: length });\n      gsap.to(trendPath, {\n          strokeDashoffset: 0,\n          duration: 2,\n          ease: \"power2.inOut\",\n          delay: 0.5\n      });\n  }\n\n  const navItems = document.querySelectorAll(\".nav-item\");\n  navItems.forEach(item => {\n      const bar = item.querySelector(\".hover-bar\");\n      item.addEventListener(\"mouseenter\", () => {\n          if (!item.classList.contains('active')) {\n            animeAnimate(bar, { scaleY: [0, 1], duration: 400, easing: 'easeOutExpo' });\n          }\n      });\n      item.addEventListener(\"mouseleave\", () => {\n          if (!item.classList.contains('active')) {\n            animeAnimate(bar, { scaleY: 0, duration: 300, easing: 'easeInExpo' });\n          }\n      });\n  });\n\n  setInterval(() => {\n    const now = new Date();\n    document.getElementById(\"clock\").textContent = now.toLocaleTimeString('en-US', { hour12: false, timeZoneName: 'short' });\n  }, 1000);\n\n  const logContainer = document.getElementById(\"audit-log\");\n  const nodes = [\"NODO_042\", \"NODO_088\", \"NODO_015\", \"SYSTEM\"];\n  const messages = [\"Heartbeat acknowledged.\", \"Packet transmitted.\", \"Sync completed.\", \"Voltage stable.\"];\n\n  setInterval(() => {\n    const timeStr = new Date().toLocaleTimeString('en-US', { hour12: false }).split(' ')[0];\n    const node = nodes[Math.floor(Math.random() * nodes.length)];\n    const msg = messages[Math.floor(Math.random() * messages.length)];\n    const row = document.createElement(\"div\");\n    row.className = \"flex items-start gap-3 py-1 border-b border-[#0B0E14]/5 opacity-0\";\n    row.innerHTML = `<span class=\"opacity-40 shrink-0\">${timeStr}</span><span class=\"bg-[#00A4E4] text-white px-1 shrink-0 font-bold\">[ OK ]</span><span class=\"opacity-50 shrink-0\">${node}</span><span class=\"font-medium\">${msg}</span>`;\n    logContainer.prepend(row);\n    gsap.to(row, { opacity: 1, duration: 0.4 });\n    if (logContainer.children.length > 20) logContainer.lastElementChild.remove();\n  }, 6000);\n\n</script>\n",
